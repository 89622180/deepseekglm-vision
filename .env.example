# Middleware listen address.
HOST=0.0.0.0
PORT=8080

# Routing mode:
# default       - only switch explicitly requested multimodal model names to DEFAULT_BACKEND_BASE_URL.
# custom-vision - switch explicitly requested multimodal model names to VISION_BACKEND_*.
# custom-all    - send all specified models to CUSTOM_BACKEND_*.
ROUTE_MODE=default

# Built-in/default backend. In default mode the incoming Authorization or x-api-key is reused.
DEFAULT_BACKEND_BASE_URL=http://127.0.0.1:8090/v1

# Models that should be routed as multimodal aliases, case-insensitive.
MULTIMODAL_MODELS=GLM-5.1,GLM-5,deepseek-v4-pro,deepseek-v4-flash

# Multimodal aliases are rewritten to this real upstream model.
VISION_BACKEND_MODEL=gpt-5.4

# custom-vision mode target. Leave VISION_BACKEND_API_KEY empty to reuse the incoming key.
VISION_BACKEND_BASE_URL=
VISION_BACKEND_API_KEY=

# custom-all mode target. Leave CUSTOM_BACKEND_API_KEY empty to reuse the incoming key.
CUSTOM_BACKEND_BASE_URL=
CUSTOM_BACKEND_API_KEY=
CUSTOM_BACKEND_MODEL=

# Optional timeout for upstream calls.
UPSTREAM_TIMEOUT_MS=600000
